# Copy to .dev.vars for local wrangler dev, or set equivalent Cloudflare vars/secrets.
# Set JWT_SECRET and ADMIN_SETUP_TOKEN with `wrangler secret put` for deployed Workers.

# Long random JWT/session signing secret.
JWT_SECRET=replace-with-a-long-random-session-secret

# One-time token used at /setup to create the first admin account.
ADMIN_SETUP_TOKEN=replace-with-a-long-random-setup-token

# Public AGPL source URL displayed by the instance.
SOURCE_CODE_URL=https://example.invalid/source

# Public instance display name.
INSTANCE_NAME=QuietCollective

# Browser push notifications. Generate with `npm run vapid:generate`.
# Store deployed values with `wrangler secret put VAPID_PUBLIC_KEY`,
# `wrangler secret put VAPID_PRIVATE_KEY`, and `wrangler secret put VAPID_SUBJECT`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@example.com
